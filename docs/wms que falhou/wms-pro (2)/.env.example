PROJECT_NAME="WMS Pro"
API_V1_STR="/api"

# OBRIGATÓRIO: gere uma chave forte antes de usar em produção:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY="gere-uma-chave-segura-com-pelo-menos-32-caracteres"

ACCESS_TOKEN_EXPIRE_MINUTES=720
DATABASE_URL_SQLITE="sqlite+aiosqlite:///./wms.db"
# DATABASE_URL_POSTGRES="postgresql+asyncpg://user:pass@localhost/wms"
BACKEND_CORS_ORIGINS='["http://127.0.0.1:8000","http://localhost:8000"]'
# Pasta monitorada para XMLs de NF-e (watcher automático)
# Use caminho absoluto em produção. Padrão: ./nfe_xml (relativo ao diretório de execução)
NFE_XML_DIR="./nfe_xml"
